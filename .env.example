# Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot
# Get your ID from @userinfobot
ALLOWED_USER_IDS=

# Public HTTPS URL for webhook mode (leave empty to use polling instead)
WEBHOOK_BASE_URL=
WEBHOOK_PORT=8080

# Working directory the agent operates in
AGENT_WORKDIR=.
